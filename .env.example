# Public HTTPS URL of the TON Connect manifest (must be reachable by wallets, no CORS/auth).
# In production: https://bid.tg/tonconnect-manifest.json
VITE_TONCONNECT_MANIFEST_URL=https://bid.tg/tonconnect-manifest.json

# Base URL of the bid.tg backend API (Fastify). Leave empty to use the built-in mock layer.
VITE_API_BASE_URL=

# Treasury wallet that collects bid.tg fees (user-friendly base64url address).
VITE_TREASURY_ADDRESS=UQA0odVR0IIwT7cZqYn_ugtv5r4RRPPlkdlGt5H5Wa6K8Qez

# TonAPI base + optional key for higher rate limits (public endpoints work without a key).
VITE_TONAPI_BASE=https://tonapi.io
